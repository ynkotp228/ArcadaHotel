---
// Форма зворотного зв'язку. Надсилання через Formspree (AJAX, без перезавантаження).
---

<section class="bg-cream-dark/40">
	<div class="section max-w-2xl">
		<h2 class="section-title">Маєте запитання?</h2>
		<div class="section-rule"></div>
		<p class="mx-auto mb-8 max-w-xl text-center text-ink/70">
			Залиште свої контакти — і ми зв'яжемося з вами найближчим часом.
		</p>

		<form
			id="ask-form"
			action="https://formspree.io/f/xgoqbjqw"
			method="POST"
			class="rounded-2xl border border-cream-dark bg-white/90 p-7 shadow-lg shadow-navy/5 sm:p-9"
		>
			<div class="flex flex-col gap-5">
				<div>
					<label for="name" class="mb-1.5 block text-sm font-medium text-navy">
						Ваше ім'я
					</label>
					<input
						type="text"
						id="name"
						name="name"
						minlength="2"
						required
						placeholder="Мінімум 2 символи"
						class="w-full rounded-lg border border-cream-dark bg-cream/40 px-4 py-2.5 text-ink outline-none transition focus:border-bronze focus:ring-2 focus:ring-bronze/30"
					/>
					<p class="field-error mt-1.5 hidden text-sm text-red-600" data-error-for="name"></p>
				</div>

				<div>
					<label for="tel" class="mb-1.5 block text-sm font-medium text-navy">
						Ваш телефон
					</label>
					<input
						type="tel"
						id="tel"
						name="tel"
						pattern="\+380\d{9}"
						required
						placeholder="+380XXXXXXXXX"
						class="w-full rounded-lg border border-cream-dark bg-cream/40 px-4 py-2.5 text-ink outline-none transition focus:border-bronze focus:ring-2 focus:ring-bronze/30"
					/>
					<p class="field-error mt-1.5 hidden text-sm text-red-600" data-error-for="tel"></p>
				</div>

				<div>
					<label for="message" class="mb-1.5 block text-sm font-medium text-navy">
						Ваше запитання
					</label>
					<textarea
						id="message"
						name="message"
						rows="4"
						minlength="10"
						required
						placeholder="Розкажіть, що вас цікавить (мінімум 10 символів)"
						class="w-full resize-y rounded-lg border border-cream-dark bg-cream/40 px-4 py-2.5 text-ink outline-none transition focus:border-bronze focus:ring-2 focus:ring-bronze/30"
					></textarea>
					<p class="field-error mt-1.5 hidden text-sm text-red-600" data-error-for="message"></p>
				</div>

				<button type="submit" class="btn w-full sm:w-auto sm:self-start">
					Надіслати
				</button>

				<!-- Повідомлення про результат -->
				<p
					id="form-status"
					class="hidden rounded-lg px-4 py-3 text-sm font-medium"
					role="status"
					aria-live="polite"
				>
				</p>
			</div>
		</form>
	</div>
</section>

<script>
	const form = document.getElementById("ask-form") as HTMLFormElement | null;
	const status = document.getElementById("form-status");

	if (form && status) {
		const nameInput = form.elements.namedItem("name") as HTMLInputElement;
		const telInput = form.elements.namedItem("tel") as HTMLInputElement;
		const messageInput = form.elements.namedItem("message") as HTMLTextAreaElement;

		// Загальний статус (успіх / помилка надсилання).
		const show = (msg: string, ok: boolean) => {
			status.textContent = msg;
			status.classList.remove("hidden");
			status.classList.toggle("bg-green-100", ok);
			status.classList.toggle("text-green-800", ok);
			status.classList.toggle("bg-red-100", !ok);
			status.classList.toggle("text-red-800", !ok);
		};

		// Показати / приховати помилку конкретного поля.
		const setFieldError = (input: HTMLInputElement | HTMLTextAreaElement, msg: string) => {
			const errorEl = form.querySelector<HTMLElement>(`[data-error-for="${input.name}"]`);
			if (msg) {
				if (errorEl) {
					errorEl.textContent = msg;
					errorEl.classList.remove("hidden");
				}
				input.classList.add("border-red-500", "focus:border-red-500", "focus:ring-red-500/30");
				input.setAttribute("aria-invalid", "true");
			} else {
				if (errorEl) {
					errorEl.textContent = "";
					errorEl.classList.add("hidden");
				}
				input.classList.remove("border-red-500", "focus:border-red-500", "focus:ring-red-500/30");
				input.removeAttribute("aria-invalid");
			}
		};

		// Повертає текст помилки українською або "" якщо поле валідне.
		const validateName = (): string => {
			const value = nameInput.value.trim();
			if (!value) return "Будь ласка, введіть ваше ім'я.";
			if (value.length < 2) return "Ім'я має містити щонайменше 2 символи.";
			return "";
		};

		const validateTel = (): string => {
			const value = telInput.value.trim();
			if (!value) return "Будь ласка, введіть номер телефону.";
			if (!/^\+380\d{9}$/.test(value)) {
				return "Невірний формат. Введіть номер у вигляді +380XXXXXXXXX (12 цифр).";
			}
			return "";
		};

		const validateMessage = (): string => {
			const value = messageInput.value.trim();
			if (!value) return "Будь ласка, опишіть ваше запитання.";
			if (value.length < 10) {
				return `Повідомлення занадто коротке (мінімум 10 символів, зараз ${value.length}).`;
			}
			return "";
		};

		// Підставляємо +380 при фокусі, якщо поле порожнє.
		telInput.addEventListener("focus", () => {
			if (!telInput.value) telInput.value = "+380";
		});

		// Прибираємо +380, якщо користувач нічого не дописав.
		telInput.addEventListener("blur", () => {
			if (telInput.value === "+380") telInput.value = "";
		});

		// Перевірка поля «на льоту» після першої взаємодії.
		nameInput.addEventListener("blur", () => setFieldError(nameInput, validateName()));
		nameInput.addEventListener("input", () => {
			if (nameInput.getAttribute("aria-invalid")) setFieldError(nameInput, validateName());
		});

		telInput.addEventListener("blur", () => {
			if (telInput.value) setFieldError(telInput, validateTel());
		});
		telInput.addEventListener("input", () => {
			if (telInput.getAttribute("aria-invalid")) setFieldError(telInput, validateTel());
		});

		messageInput.addEventListener("blur", () => setFieldError(messageInput, validateMessage()));
		messageInput.addEventListener("input", () => {
			if (messageInput.getAttribute("aria-invalid")) setFieldError(messageInput, validateMessage());
		});

		form.addEventListener("submit", async (e) => {
			e.preventDefault();

			// Перевіряємо всі поля перед надсиланням.
			const errors = {
				name: validateName(),
				tel: validateTel(),
				message: validateMessage(),
			};
			setFieldError(nameInput, errors.name);
			setFieldError(telInput, errors.tel);
			setFieldError(messageInput, errors.message);

			const firstInvalid = [nameInput, telInput, messageInput].find(
				(input) => input.getAttribute("aria-invalid"),
			);
			if (firstInvalid) {
				show("Будь ласка, виправте помилки у формі.", false);
				firstInvalid.focus();
				return;
			}

			const data = new FormData(form);
			try {
				const res = await fetch(form.action, {
					method: "POST",
					body: data,
					headers: { Accept: "application/json" },
				});
				if (res.ok) {
					show("Дякуємо! Ваше повідомлення надіслано.", true);
					form.reset();
				} else {
					show("Не вдалося надіслати. Спробуйте пізніше.", false);
				}
			} catch {
				show("Помилка мережі. Перевірте з'єднання.", false);
			}
		});
	}
</script>
