---
const { CarouselTitle, slogan, bgimage, link, buttonText } = Astro.props;
---

<div
	class="relative flex min-h-96 w-full shrink-0 grow-0 basis-full items-end overflow-hidden rounded-3xl bg-cover bg-center sm:min-h-112 md:min-h-128"
	style={`background-image: url('${bgimage}')`}
>
	<div
		class="absolute inset-0 bg-linear-to-t from-navy/85 via-navy/35 to-transparent"
		aria-hidden="true"
	>
	</div>
	<div class="relative z-10 max-w-xl p-6 text-cream sm:p-10">
		<h3 class="text-cream! text-2xl font-bold sm:text-3xl md:text-4xl">
			{CarouselTitle}
		</h3>
		<p class="mt-3 text-sm text-cream/90 sm:text-base">{slogan}</p>
		<a href={link} class="btn mt-5">{buttonText}</a>
	</div>
</div>
