---
import  Adress from './Adress.astro';   
import SocialMedia from './SocialMedia.astro';
interface Props {
    title: string;
    description: string;
    heroButtontext: string;
    heroButtonLink: string;
    showAddress: boolean;
    showSocialMedia: boolean;
    bgimage: string;
}
const { showSocialMedia = false, showAddress = false, title, description, heroButtontext, heroButtonLink, bgimage } = Astro.props;
---



<section
    id="hero"
    class="grid grid-cols-3 bg-cover bg-center bg-no-repeat min-h-screen"
    style={`background-image: url('${bgimage}')`}
>
    {showAddress && <Adress />}
    <div >
        <h1>{title}</h1>
        <p>{description}</p>
        <a href={heroButtonLink} class="btn">{heroButtontext}</a>
    </div>
     {showSocialMedia && <SocialMedia />}

</section>