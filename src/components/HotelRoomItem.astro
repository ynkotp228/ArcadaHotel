---
const { roomType, roomDescription, bgimage, roomPrice } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<article
	class="group flex flex-col overflow-hidden rounded-2xl border border-cream-dark bg-white/90 shadow-lg shadow-navy/5 transition hover:-translate-y-1 hover:shadow-xl"
>
	<div class="relative h-56 overflow-hidden">
		<div
			class="h-full w-full bg-cover bg-center transition duration-500 group-hover:scale-105"
			style={`background-image: url('${bgimage}')`}
			role="img"
			aria-label={roomType}
		>
		</div>
		<span
			class="absolute right-3 top-3 rounded-full bg-navy/90 px-3 py-1 text-sm font-semibold text-cream backdrop-blur"
		>
			{roomPrice}
		</span>
	</div>

	<div class="flex flex-1 flex-col p-6">
		<h3 class="mb-2 text-xl font-semibold">{roomType}</h3>
		{
			roomDescription?.trim() && (
				<p class="mb-5 text-sm leading-relaxed text-ink/70">
					{roomDescription}
				</p>
			)
		}
		<a href={`${base}soon`} class="btn mt-auto w-full">Забронювати</a>
	</div>
</article>
