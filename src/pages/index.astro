---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import Contacts from '../components/Contacts.astro';
import AboutUs from '../components/AboutUs.astro';
import heroImg from '../assets/images/heroMainPage.webp';
import AboutUsImg from "../assets/images/aboutUsMainPage.webp";
---
<Layout title="Arcada Hotel — Готель у серці Львова">
	<Header />
	<Hero bgimage={heroImg.src} title="Arcada Hotel" description='Ласкаво просимо на наш офіційний сайт ресторанно-готельного комплексу у самому серці Львова' heroButtonLink='/Hotel' heroButtontext='Наші апартаменти' showAddress={true} showSocialMedia={true} />
	<Services />
	<AboutUs bgimage={AboutUsImg.src} />
	<Contacts />
	<Footer />

</Layout>