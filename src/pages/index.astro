---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import Contacts from '../components/Contacts.astro';
import AboutUs from '../components/AboutUs.astro';
import heroImg from '../assets/images/heroMainPage.webp';
import AboutUsImg from "../assets/images/aboutUsMainPage.webp";
const base = import.meta.env.BASE_URL;
---
<Layout title="Arcada Hotel — більше ніж просто ночівля.">
	 
	<Hero bgimage={heroImg} title="Arcada Hotel" description='Ласкаво просимо на офіційний сайт ресторанно-готельного комплексу неподалік історичного серця Львова.' heroButtonLink={`${base}/Hotel`} heroButtontext='Наші апартаменти' showAddress={true} showSocialMedia={true} />
	<Services />
	<AboutUs bgimage={AboutUsImg.src} />
	<Contacts />
	 

</Layout>