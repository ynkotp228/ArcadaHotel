---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import HotelRoom from '../components/HotelRoom.astro';
import AskForm from '../components/AskForm.astro';
import Footer from '../components/Footer.astro';
import heroImage from '../assets/images/carouselCard1.webp';
const base = import.meta.env.BASE_URL;
---

<Layout title="Готель — Arcada Hotel">
    <Header />
    <Hero  bgimage={heroImage.src} title="Arcada Hotel" description="Ваш ідеальний вибір апартаментів у самому серці Львова" heroButtontext="Забронювати номер" heroButtonLink={`${base}soon`} showAddress={false} showSocialMedia={false} />
    <HotelRoom />
    <AskForm />
    <Footer />
</Layout>   