---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import HotelRoom from '../components/HotelRoom.astro';
import AskForm from '../components/AskForm.astro';
import heroImage from '../assets/images/carouselCard1.webp';
const base = import.meta.env.BASE_URL;
---

<Layout title="Готель — Arcada Hotel">
     
    <Hero  bgimage={heroImage} title="Arcada Hotel" description="Ваш ідеальний вибір апартаментів неподалік історичного серця Львова" heroButtontext="Забронювати номер" heroButtonLink={`${base}soon`} showAddress={false} showSocialMedia={false} />
    <HotelRoom />
    <AskForm />
    
</Layout>   