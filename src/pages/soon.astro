---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import logo from '../assets/images/logo.webp';
const base = import.meta.env.BASE_URL;
---

<Layout title="Незабаром — Arcada Hotel">
	 
	<main
		class="flex min-h-[70vh] flex-col items-center justify-center px-5 py-20 text-center"
	>
		<Image
			src={logo}
			alt="Arcada Hotel"
			width={224}
			height={224}
			loading="eager"
			class="mb-8 h-28 w-28 rounded-full object-cover shadow-lg ring-4 ring-cream-dark"
		/>
		<p
			class="mb-3 text-sm font-semibold uppercase tracking-[0.2em] text-bronze"
		>
			Незабаром
		</p>
		<h1 class="mb-5 text-3xl sm:text-4xl md:text-5xl">
			Вибачте, це поки що тестовий сайт 🙏
		</h1>
		<p class="max-w-xl text-base leading-relaxed text-ink/75 sm:text-lg">
			Це сайт для мого портфоліо, тому забронювати чи замовити тут нічого не
			можна. Усі дані вигадані, а функції бронювання — лише демонстрація
			інтерфейсу.
		</p>
		<a href={base} class="btn mt-8"> ← Повернутися на головну </a>
	</main>
	 
</Layout>
