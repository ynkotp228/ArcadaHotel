---
import '../assets/styles/global.css';

interface Props {
	title?: string;
}
const { title = 'Arcada Hotel —  ваш найкращий вибір готелю у Львові' } = Astro.props;
---

<!doctype html>
<html lang="uk">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
		<meta
			name="description"
			content="Arcada Hotel - Готель у серці Львова. Відкрийте для себе комфорт та гостинність в нашому готелі, розташованому в самому центрі Львова. Забронюйте номер вже сьогодні!"
		/>

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600;700&family=Inter:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>

		<title>{title}</title>
	</head>
	<body class="bg-cream text-ink font-body antialiased">
		<slot />
		<script>
			import '../scripts/menu.js';
		</script>
	</body>
</html>
